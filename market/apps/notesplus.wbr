{
  "id": "notesplus",
  "name": "Notes+",
  "icon": "StickyNote",
  "permissions": [],
  "code": "return function NotesPlus() { const [notes, setNotes] = React.useState(() => { return localStorage.getItem('notesplus_content') || ''; }); React.useEffect(() => { localStorage.setItem('notesplus_content', notes); }, [notes]); return React.createElement('div', {className: 'h-full p-6', style: {backgroundColor: '#fdfd96'}}, React.createElement('textarea', {className: 'w-full h-full bg-transparent resize-none outline-none text-gray-800 text-xl font-serif leading-relaxed', placeholder: 'Write your notes here...', value: notes, onChange: e => setNotes(e.target.value), spellCheck: false})); }"
}
