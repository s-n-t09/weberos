  "code": "return function WeSandBox() { class ErrorBoundary extends React.Component { constructor(props) { super(props); this.state = { hasError: false, error: null }; } static getDerivedStateFromError(error) { return { hasError: true, error }; } render() { if (this.state.hasError) return React.createElement('div', {className: 'text-red-500 p-4 font-mono'}, this.state.error.toString()); return this.props.children; } } const defaultCode = \"return () => React.createElement('div', {className: 'h-full flex items-center justify-center bg-purple-600 text-white text-2xl font-bold'}, 'Hello World!')\"; const [code, setCode] = React.useState(() => { return localStorage.getItem('wesandbox_code') || defaultCode; }); React.useEffect(() => { localStorage.setItem('wesandbox_code', code); }, [code]); const handleSave = async () => { try { const path = await Sys.fs.openFileSaver(); if (path) { Sys.fs.writeFile(path, code); Sys.notify('Saved', 'File saved successfully!'); } } catch (e) { Sys.notify('Error', e.toString()); } }; const Preview = React.useMemo(() => { try { const fn = new Function('React', code); const res = fn(React); if (typeof res === 'function') { return res; } return () => res; } catch (e) { return () => React.createElement('div', {className: 'text-red-500 p-4 font-mono'}, e.toString()); } }, [code]); return React.createElement('div', {className: 'flex h-full flex-col'}, React.createElement('div', {className: 'h-12 bg-slate-800 flex items-center justify-between px-4 text-white font-bold'}, 'WeSandBox - Live .wbr Editor', React.createElement('button', { className: 'px-3 py-1 bg-blue-600 hover:bg-blue-500 rounded text-sm', onClick: handleSave }, 'Save to FS')), React.createElement('div', {className: 'flex flex-1 overflow-hidden'}, React.createElement('textarea', {className: 'w-1/2 h-full p-4 bg-slate-950 text-green-400 font-mono resize-none outline-none', value: code, onChange: e => setCode(e.target.value), spellCheck: false}), React.createElement('div', {className